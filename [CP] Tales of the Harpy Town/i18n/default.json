    "CheshiresAtelier.THTexpansion_RejectMPnpcWithSomeoneElseAdrianno": "W-well... There's a certain someone...$2",
    "CheshiresAtelier.THTexpansion_RejectMPplayerWithSomeoneElseAdrianno": "A-aren't you married?!$10",
    "CheshiresAtelier.THTexpansion_RejectMPunder8HeartsAdrianno": "This is crazy, @... Of course not!$5",
    "CheshiresAtelier.THTexpansion_RejectMPunder10HeartsAdrianno": "I'm sorry, @, but I'm not ready for that...$2",
    "CheshiresAtelier.THTexpansion_RejectMPunder10HeartsAgainAdrianno": "I'm still not ready for that...$5",
    "CheshiresAtelier.THTexpansion_RejectMPAdrianno": "I'm sorry, @, but this is too much...$2",
    "CheshiresAtelier.THTexpansion_RejectRoommateProposalAdrianno": "I still have duties to do at home...$2",
    "CheshiresAtelier.THTexpansion_RejectMovieTicketAdrianno": "I'm busy, sorry.$2",

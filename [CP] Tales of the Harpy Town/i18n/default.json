    "CheshiresAtelier.THTexpansion_QuestTitle01": "Harpy town's debris.",
    "CheshiresAtelier.THTexpansion_QuestDesc01": "Deliver 1,000 wood, 500 stone, and 15 iron bars to the Backwoods box.",
    "CheshiresAtelier.THTexpansion_QuestDesc02": "Deliver 1,000 wood to the Backwoods box.",
    "CheshiresAtelier.THTexpansion_QuestDesc03": "Deliver 500 stone to the Backwoods box.",
    "CheshiresAtelier.THTexpansion_QuestDesc04": "Deliver 15 iron bars to the Backwoods box.",
    "CheshiresAtelier.THTexpansion_QuestTitle02": "Go to the backwoods stairs.",
    "CheshiresAtelier.THTexpansion_QuestDesc0102": "It's done! Go to the backwoods stairs.",
    "CheshiresAtelier.THTexpansion_QuestTitle03": "Restore an abandoned house.",
    "CheshiresAtelier.THTexpansion_QuestDesc05": "Me and my family are organizing ourselves to refurnish that old house next to the lake for a friend of ours and his family, but we need help with the materials.",
    "CheshiresAtelier.THTexpansion_QuestDesc06": "Deliver 100 clay to the Harpy town's box, positioned next to Francisco's house.",
    "CheshiresAtelier.THTexpansion_QuestDesc07": "Deliver 500 stone to the Harpy town's box, positioned next to Francisco's house.",
    "CheshiresAtelier.THTexpansion_QuestDesc08": "Deliver 50 iron bars to the Harpy town's box, positioned next to Francisco's house.",

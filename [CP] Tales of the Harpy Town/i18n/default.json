    "CheshiresAtelier.THTexpansion_Fish13": "Dogfish", //Cação
    "CheshiresAtelier.THTexpansion_Fish13Desc": "It doesn't bark.",
    "CheshiresAtelier.THTexpansion_Fish14": "Salema",
    "CheshiresAtelier.THTexpansion_Fish14Desc": "Eating this little fish might cause you some hallucinating effects...",
    "CheshiresAtelier.THTexpansion_Fish15": "Smooth Weakfish", //Pescada branca
    "CheshiresAtelier.THTexpansion_Fish15Desc": "Despite the ''weak'' in its name, this fish is tougher than it looks.",
    "CheshiresAtelier.THTexpansion_Fish16": "Atlantic Moonfish", //Peixe galo
    "CheshiresAtelier.THTexpansion_Fish16Desc": "This big ass forehead...",
    "CheshiresAtelier.THTexpansion_Fish17": "Mackerel", //Cavalinha
    "CheshiresAtelier.THTexpansion_Fish17Desc": "A fast swimmer that travels in large schools.",
    "CheshiresAtelier.THTexpansion_Fish18": "Barracuda",
    "CheshiresAtelier.THTexpansion_Fish18Desc": "A large predator with sharp and scary teeth.",
    "CheshiresAtelier.THTexpansion_Fish19": "Needlefish", //Peixe agulha
    "CheshiresAtelier.THTexpansion_Fish19Desc": "Not worth very much, but has a funny appearance.",
    "CheshiresAtelier.THTexpansion_Fish20": "Cobia", //Bijupirá
    "CheshiresAtelier.THTexpansion_Fish20Desc": "This one is quite a job to catch!",
    "CheshiresAtelier.THTexpansion_Fish21": "Namorado Sandperch", // Namorado
    "CheshiresAtelier.THTexpansion_Fish21Desc": "''Boyfriend Sandperch''... Who even decides these names??",
    "CheshiresAtelier.THTexpansion_Fish22": "Dolphinfish", //Mahi Mahi/ dourado do mar
    "CheshiresAtelier.THTexpansion_Fish22Desc": "Also called Mahi Mahi, and also has a big ass forehead.",
    "CheshiresAtelier.THTexpansion_Fish23": "Yellowtail Amberjack",
    "CheshiresAtelier.THTexpansion_Fish23Desc": "This little one can put even the skilled of anglers to the test.",
    "CheshiresAtelier.THTexpansion_Fish24": "Monkfish",
    "CheshiresAtelier.THTexpansion_Fish24Desc": "An odd-looking ambush predator with a face only a mother could love. (Please show this little one a bit of love)",
    "CheshiresAtelier.THTexpansion_Fish25": "Guitarfish",
    "CheshiresAtelier.THTexpansion_Fish25Desc": "It's not a guitar, it's a fish.",
    "CheshiresAtelier.THTexpansion_Fish26": "Opah",
    "CheshiresAtelier.THTexpansion_Fish26Desc": "One of the few fish capable of keeping its body warmer than the surrounding water.",
    "CheshiresAtelier.THTexpansion_Fish27": "Pufferkitty",
    "CheshiresAtelier.THTexpansion_Fish27Desc": "Ah... Nature sure is perfect, isn't it?",
    "CheshiresAtelier.THTexpansion_Fish28": "Titanoboa",
    "CheshiresAtelier.THTexpansion_Fish28Desc": "How did you even manage to catch this big guy before it eats you alive?",
    "CheshiresAtelier.THTexpansion_Fish29": "Oarfish",
    "CheshiresAtelier.THTexpansion_Fish29Desc": "A mysterious deep-sea fish that has inspired countless tales among sailors.",
    //Fruit trees and stuff'-'
    "CheshiresAtelier.THTexpansion_Fruit": "Palm Oil Fruit",
    "CheshiresAtelier.THTexpansion_FruitDesc": "Known by its delicious oil.",
    "CheshiresAtelier.THTexpansion_FruitSapling": "Palm Oil Fruit Sapling",
    "CheshiresAtelier.THTexpansion_FruitSaplingDesc": "Takes 28 days to produce a mature Palm Oil tree. Bears fruit in the Spring. Only grows if the 8 surrounding ''Tiles'' are empty.",
    "CheshiresAtelier.THTexpansion_Fruit1": "Moriche Palm Fruit",
    "CheshiresAtelier.THTexpansion_Fruit1Desc": "Its skin looks like a lizard's.",
    "CheshiresAtelier.THTexpansion_Fruit1Sapling": "Moriche Palm Fruit Sapling",
    "CheshiresAtelier.THTexpansion_Fruit1SaplingDesc": "Takes 28 days to produce a mature Palm Oil tree. Bears fruit in the Fall. Only grows if the 8 surrounding ''Tiles'' are empty.",
    "CheshiresAtelier.THTexpansion_Fruit2": "Pindó-Rama Cocoa",
    "CheshiresAtelier.THTexpansion_Fruit2Desc": "Used to make chocolate.",
    "CheshiresAtelier.THTexpansion_Fruit2Sapling": "Pindó-Rama Cocoa Sapling",
    "CheshiresAtelier.THTexpansion_Fruit2SaplingDesc": "Takes 28 days to produce a mature Palm Oil tree. Bears fruit in the Spring. Only grows if the 8 surrounding ''Tiles'' are empty.",
    "CheshiresAtelier.THTexpansion_Fruit3": "Jatobá",
    "CheshiresAtelier.THTexpansion_Fruit3Desc": "A sweet fruit with a hard skin.",

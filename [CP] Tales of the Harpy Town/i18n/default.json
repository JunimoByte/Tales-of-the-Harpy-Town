    //Adrianno
    "CheshiresAtelier.THTexpansion_IntroductionAdrianno": "Hello! You must be @.#$b#Nice to meet you, my name is Adrianno! I work as Joja Corporation's security guard at night, so you can ask me for help if you need!$1",
    "CheshiresAtelier.THTexpansion_DumpsterDiveCommentAdrianno": "You have... Interesting tastes, @...",
